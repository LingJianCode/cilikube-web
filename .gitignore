# Git 会忽略的文件

.DS_Store
node_modules
dist
dist-ssr
.eslintcache

# Local env files（真实环境配置勿提交；用 *.example 作为模板）
*.local
.env
.env.*
!.env.example
!.env.*.example

# Editor / backup junk
*.backup
*.bak

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/*.code-snippets
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Use the PNPM
package-lock.json
yarn.lock
